# ===========================
# Training Planner AI — Environment Variables
# ===========================
# Copy this file to .env.local and fill in actual values.
# Never commit .env.local to git.

# ---------------------------
# Supabase — required
# ---------------------------
# Get from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Service role key — SERVER SIDE ONLY, never expose to client
# Used for admin operations (migrations, RLS bypass in RPC)
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ---------------------------
# Anthropic Claude API — required
# ---------------------------
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Model override (optional, defaults to claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------------------------
# Next.js — required
# ---------------------------
# Base URL of the app (for callbacks, metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------
# Sentry — optional (production only)
# ---------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ---------------------------
# Rate limiting (optional, defaults OK)
# ---------------------------
# Max AI plan generations per minute per trainer
AI_RATE_LIMIT_PER_MIN=3

# ---------------------------
# Playwright E2E (required for authenticated E2E)
# ---------------------------
# URL of preview/staging deployment tested by Playwright.
PLAYWRIGHT_BASE_URL=

# Test coach account used by E2E auth scenarios.
E2E_COACH_EMAIL=
E2E_COACH_PASSWORD=
